
# ==============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and replace the placeholder values with your actual data.
# DO NOT commit the actual .env file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Google OAuth Configuration
# ------------------------------------------------------------------------------
# Get your Google Client ID from: https://console.cloud.google.com/
# 1. Create a new project in Google Cloud Console
# 2. Enable Google+ API (or Google People API)
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URIs: https://your-hostinger-domain.com/callback
REACT_APP_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# ------------------------------------------------------------------------------
# API Configuration
# ------------------------------------------------------------------------------
# For Hostinger deployment, use your actual domain
# Local development: http://localhost:3000/api
# Production: https://your-hostinger-domain.com/api
REACT_APP_API_BASE_URL=https://your-hostinger-domain.com/api

# ------------------------------------------------------------------------------
# Environment Settings
# ------------------------------------------------------------------------------
REACT_APP_ENVIRONMENT=production
NODE_ENV=production

# ------------------------------------------------------------------------------
# Database Configuration (for backend/server setup)
# ------------------------------------------------------------------------------
# PostgreSQL format: postgresql://user:password@localhost:5432/property_db
# MySQL format: mysql://user:password@localhost:3306/property_db
# Replace with the credentials provided in your Hostinger hPanel
DATABASE_URL=your_database_connection_string_here

# ------------------------------------------------------------------------------
# Email Configuration (Hostinger SMTP)
# ------------------------------------------------------------------------------
# NOTE: Email notifications are currently simulated in the frontend.
# For production deployment, configure these variables in your backend environment.
# Hostinger SMTP settings:
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=your-email@your-domain.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@your-domain.com
