# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/dehradun_estates
# Or use individual connection params:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=dehradun_estates
# DB_USER=username
# DB_PASSWORD=password

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Google OAuth (for verifying tokens from frontend)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Email Configuration (Hostinger SMTP)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@your-domain.com
SMTP_PASS=your-email-password
EMAIL_FROM=Dehradun Estates <noreply@your-domain.com>

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads