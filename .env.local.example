
# ==============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT CONFIGURATION
# Copy this file to .env.local for local development.
# ==============================================================================

# Google OAuth Configuration (Local)
# Ensure http://localhost:3000 is added to your Authorized JavaScript origins
# and Authorized redirect URIs in Google Cloud Console.
REACT_APP_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# API Configuration (Local)
REACT_APP_API_BASE_URL=http://localhost:3000/api

# Environment Settings
REACT_APP_ENVIRONMENT=development
NODE_ENV=development

# Database Configuration (Local)
# Example for local MySQL: mysql://root:password@localhost:3306/property_db_local
DATABASE_URL=mysql://root:password@localhost:3306/property_db_local
